<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.Cursor?>
<?import javafx.scene.effect.Glow?>
<?import javafx.scene.layout.*?>
<VBox prefHeight="720.0" prefWidth="1280.0" stylesheets="@../styles/index.css" xmlns="http://javafx.com/javafx/25"
      xmlns:fx="http://javafx.com/fxml/1" fx:controller="br.com.getronics.controllers.HomeController">
    <HBox alignment="CENTER" nodeOrientation="LEFT_TO_RIGHT" VBox.vgrow="ALWAYS">
        <AnchorPane prefWidth="630.0" HBox.hgrow="SOMETIMES">
            <HBox.margin>
                <Insets bottom="10.0" left="10.0" right="10.0" top="10.0"/>
            </HBox.margin>
            <Separator layoutY="296.0" prefHeight="5.0" AnchorPane.leftAnchor="10.0" AnchorPane.rightAnchor="10.0"/>
            <Label text="Configuração e Progresso"/>
            <Button layoutX="14.0" layoutY="40.0" mnemonicParsing="false" onAction="#selectWorkBooks" prefHeight="180.0"
                    prefWidth="200.0" text="Selecionar Planilha(s)" AnchorPane.leftAnchor="10.0"
                    AnchorPane.topAnchor="40.0">
                <cursor>
                    <Cursor fx:constant="HAND"/>
                </cursor>
                <effect>
                    <Glow/>
                </effect>
            </Button>
            <ScrollPane fx:id="spSelectedFiles" layoutX="215.0" layoutY="40.0" prefHeight="180.0" prefWidth="400.0"
                        AnchorPane.rightAnchor="10.0" AnchorPane.topAnchor="40.0">
                <VBox fx:id="vBoxSelectedFiles" fillWidth="false">
                    <padding>
                        <Insets topRightBottomLeft="5" />
                    </padding>
                    <Label text="(Nenhuma planilha selecionada)" VBox.vgrow="ALWAYS">
                        <VBox.margin>
                            <Insets left="5.0" top="5.0"/>
                        </VBox.margin>
                    </Label>
                </VBox>
            </ScrollPane>
            <ProgressBar layoutY="236.0" prefHeight="25.0" progress="0.0" AnchorPane.leftAnchor="10.0"
                         AnchorPane.rightAnchor="10.0"/>
            <Label fx:id="lblProgressBar" layoutY="267.0" text="Progresso: 0/60 Planilhas"/>
            <Label layoutY="307.0" text="Selecionar pasta de saída:"/>
            <Pane layoutY="333.0">
                <Button fx:id="btnPickOutputDir" mnemonicParsing="false" text="Selecionar">
                    <cursor>
                        <Cursor fx:constant="HAND"/>
                    </cursor>
                    <effect>
                        <Glow/>
                    </effect>
                </Button>
                <Label fx:id="lblOutputDir" layoutX="100.0" layoutY="7.0" text="caminho selecionado..."/>
            </Pane>
            <Button fx:id="btnStart" alignment="BOTTOM_CENTER" layoutX="109.0" layoutY="630.0" mnemonicParsing="false"
                    prefWidth="200.0" text="Iniciar">
                <cursor>
                    <Cursor fx:constant="HAND"/>
                </cursor>
                <effect>
                    <Glow/>
                </effect>
            </Button>
        </AnchorPane>
        <AnchorPane HBox.hgrow="ALWAYS">
            <HBox.margin>
                <Insets bottom="10.0" left="10.0" right="10.0" top="10.0"/>
            </HBox.margin>
            <Label text="Log de Análise / Erros:" AnchorPane.leftAnchor="0.0" AnchorPane.topAnchor="0.0"/>
            <ScrollPane layoutY="30.0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0"
                        AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="30.0">
                <VBox fx:id="vboxLog" fillWidth="false" spacing="5.0">
                    <padding>
                        <Insets bottom="10.0" left="10.0" right="10.0" top="10.0"/>
                    </padding>
                </VBox>
            </ScrollPane>
        </AnchorPane>
    </HBox>
</VBox>
